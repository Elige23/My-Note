<?xml version="1.0" encoding="utf-8"?>
<!--
    Navigation graph for the Notes feature.

    Destinations:
    - noteHomeFragment: Main screen with notes list (start destination)
    - addNoteFragment: Create a new note
    - editNoteFragment: Edit an existing note (receives noteId argument)

    Scroll flags (scrollFlagFromEdit/scrollFlagFromAdd) control automatic
    scrolling to the top when returning from edit/add screens.

    Both add and edit fragments pop back to home after saving/canceling.
-->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_note"
    app:startDestination="@id/noteHomeFragment">

    <fragment
        android:id="@+id/noteHomeFragment"
        android:name="com.example.mynote.view.fragments.NoteHomeFragment"
        android:label="home_note_fragment"
        tools:layout="@layout/fragment_note_home">

        <argument
            android:name="scrollFlagFromEdit"
            app:argType="boolean" />

        <argument
            android:name="scrollFlagFromAdd"
            app:argType="boolean" />

        <action
            android:id="@+id/action_noteHomeFragment_to_addNoteFragment"
            app:destination="@id/addNoteFragment" />

        <action
            android:id="@+id/action_noteHomeFragment_to_editNoteFragment"
            app:destination="@id/editNoteFragment" />
    </fragment>

    <fragment
        android:id="@+id/editNoteFragment"
        android:name="com.example.mynote.view.fragments.NoteEditFragment"
        android:label="edit_note_fragment"
        tools:layout="@layout/fragment_edit_note">

        <argument
            android:name="noteIdFromHome"
            app:argType="integer" />

        <action
            android:id="@+id/action_editNoteFragment_to_noteHomeFragment"
            app:destination="@id/noteHomeFragment"
            app:popUpTo="@id/noteHomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/addNoteFragment"
        android:name="com.example.mynote.view.fragments.NoteAddFragment"
        android:label="add_note_fragment"
        tools:layout="@layout/fragment_add_note">

        <action
            android:id="@+id/action_addNoteFragment_to_noteHomeFragment"
            app:destination="@id/noteHomeFragment"
            app:popUpTo="@id/noteHomeFragment"
            app:popUpToInclusive="true" />
    </fragment>
</navigation>